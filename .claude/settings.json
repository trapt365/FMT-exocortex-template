{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Edit(/.claude/skills/**)"
    ],
    "additionalDirectories": [
      "{{HOME_DIR}}",
      "{{HOME_DIR}}/.claude/projects",
      "{{WORKSPACE_DIR}}/.claude/skills"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wp-gate-reminder.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/close-gate-reminder.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protocol-artifact-validate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Skill",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protocol-completion-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protocol-stop-gate.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/precompact-checkpoint.sh"
          }
        ]
      }
    ]
  }
}
